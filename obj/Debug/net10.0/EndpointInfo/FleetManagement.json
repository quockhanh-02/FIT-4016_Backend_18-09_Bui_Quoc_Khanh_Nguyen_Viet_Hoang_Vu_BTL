  "components": {
    "schemas": {
      "Accident": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "vehicleId": {
            "type": "integer",
            "format": "int32"
          },
          "driverId": {
            "type": "integer",
            "format": "int32"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "damageCost": {
            "type": "number",
            "format": "double"
          },
          "vehicle": {
            "$ref": "#/components/schemas/Vehicle"
          },
          "driver": {
            "$ref": "#/components/schemas/Driver"
          }
        },
        "additionalProperties": false
      },
      "Driver": {
        "required": [
          "fullName",
          "licenseNumber"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "fullName": {
            "minLength": 1,
            "type": "string"
          },
          "licenseNumber": {
            "minLength": 1,
            "type": "string"
          },
          "licenseExpiry": {
            "type": "string",
            "format": "date-time"
          },
          "trips": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trip"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FuelLog": {
        "required": [
          "fuelDate",
          "liters",
          "odometer",
          "totalCost",
          "vehicleId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "vehicleId": {
            "type": "integer",
            "format": "int32"
          },
          "vehicle": {
            "$ref": "#/components/schemas/Vehicle"
          },
          "fuelDate": {
            "type": "string",
            "format": "date-time"
          },
          "odometer": {
            "type": "integer",
            "format": "int32"
          },
          "liters": {
            "type": "number",
            "format": "double"
          },
          "totalCost": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Maintenance": {
        "required": [
          "cost",
          "maintenanceDate",
          "status",
          "vehicleId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "vehicleId": {
            "type": "integer",
            "format": "int32"
          },
          "maintenanceDate": {
            "type": "string",
            "format": "date-time"
          },
          "cost": {
            "type": "number",
            "format": "double"
          },
          "notes": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "status": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "vehicle": {
            "$ref": "#/components/schemas/Vehicle"
          }
        },
        "additionalProperties": false
      },
      "Trip": {
        "required": [
          "endLocation",
          "startLocation"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "startLocation": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "endLocation": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "vehicleId": {
            "type": "integer",
            "format": "int32"
          },
          "vehicle": {
            "$ref": "#/components/schemas/Vehicle"
          },
          "driverId": {
            "type": "integer",
            "format": "int32"
          },
          "driver": {
            "$ref": "#/components/schemas/Driver"
          }
        },
        "additionalProperties": false
      },
      "Vehicle": {
        "required": [
          "licensePlate",
          "vehicleType"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "licensePlate": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "fuelNorm": {
            "maximum": 1000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "vehicleType": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "fuelLogs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FuelLog"
            },
            "nullable": true
          },
          "trips": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trip"
            },
            "nullable": true
          },
          "maintenances": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Maintenance"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
